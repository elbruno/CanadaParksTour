@page "/map"
@using OntarioParksExplorer.Blazor.Models
@using OntarioParksExplorer.Blazor.Services
@inject ParksApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Map View - Ontario Parks Explorer</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h3" Class="mb-4">Ontario Parks Map</MudText>

    @if (isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="600px" />
    }
    else
    {
        <MudPaper Class="pa-2 mb-4">
            <MudText Typo="Typo.body2">Showing @parks.Count parks across Ontario. Click on a marker to view park details.</MudText>
        </MudPaper>
        <MudPaper>
            <div id="mainMap" style="height: 600px; width: 100%;" role="region" aria-label="Interactive map showing locations of Ontario parks"></div>
            <p class="visually-hidden">An interactive map displaying @parks.Count Ontario parks. Each park is represented by a marker showing its location. Click markers to view park details.</p>
        </MudPaper>
    }
</MudContainer>

@code {
    private List<ParkListDto> parks = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var allParks = new List<ParkListDto>();
        int page = 1;
        PagedResultDto<ParkListDto> result;

        do
        {
            result = await ApiClient.GetParksAsync(page, 100);
            allParks.AddRange(result.Items);
            page++;
        } while (page <= result.TotalPages);

        parks = allParks;
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && parks.Any())
        {
            await JS.InvokeVoidAsync("mapInterop.initMap", "mainMap", 50.0, -85.0, 5);

            foreach (var park in parks)
            {
                var popupContent = $"<strong>{park.Name}</strong><br/>{park.Region}<br/><a href='/parks/{park.Id}'>View Details</a>";
                await JS.InvokeVoidAsync("mapInterop.addMarker", park.Latitude, park.Longitude, park.Name, popupContent);
            }
        }
    }
}

